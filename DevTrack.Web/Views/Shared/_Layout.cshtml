<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevTrack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,500;0,8..60,600;0,8..60,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DevTrack.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="topbar-left">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">D</span>
                    <span>DevTrack</span>
                </a>
                <button id="menuToggle" class="btn btn-ghost mobile-menu-btn" type="button" aria-label="Open navigation menu" aria-expanded="false">
                    <span class="hamburger-icon"></span>
                </button>
                <nav id="mainNav" class="main-nav">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Overview</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                        <a asp-area="" asp-controller="Home" asp-action="Projects">Projects</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-area="" asp-controller="Home" asp-action="Admin">Admin</a>
                    }
                </nav>
            </div>
            <div class="topbar-right">
                @* Client-side theme toggle; state persisted in localStorage. *@
                <button id="themeToggle" class="btn btn-ghost" type="button" aria-label="Toggle dark mode">
                    <span class="icon-wrap">◐</span>
                    <span>Theme</span>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="welcome-text">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">log out</button>
                    </form>
                }
                else
                {
                    <a class="btn" asp-controller="Account" asp-action="Register">register</a>
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Login">sign in</a>
                }
            </div>
        </header>

        <main class="content" role="main">
            @RenderBody()
        </main>

        <footer class="footer">
            <span>© <span id="currentYear"></span> DevTrack</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </footer>
    </div>

    @* Shared front-end behaviors: theme toggle + animation triggers. *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
