@{
    ViewData["Title"] = "Overview";
}

<section class="hero fade-in">
    <h1>Build your developer journey with clarity.</h1>
    <p class="subtitle">
        DevTrack helps software engineering students track projects, map skills, and monitor growth over time.
        Manage your portfolio, sync GitHub repositories, and keep all progress in one clean workspace.
    </p>
    <div class="hero-actions">
        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-primary">Open Dashboard</a>
        <a asp-controller="Home" asp-action="Projects" class="btn">Browse Projects</a>
    </div>
</section>

<section class="grid">
    <article class="card kpi fade-in">
        <h3>Students</h3>
        <p class="metric">@ViewBag.StudentCount</p>
        <p class="muted">Registered users</p>
    </article>

    <article class="card kpi fade-in">
        <h3>Projects</h3>
        <p class="metric">@ViewBag.ProjectCount</p>
        <p class="muted">Tracked in DevTrack</p>
    </article>

    <article class="card kpi fade-in">
        <h3>Skills</h3>
        <p class="metric">@ViewBag.SkillCount</p>
        <p class="muted">Available to tag</p>
    </article>

    <article class="card kpi fade-in">
        <h3>GitHub Sync</h3>
        <p class="status-row"><span class="dot"></span> Connected</p>
        <p class="muted">Repository metadata active</p>
    </article>

    <article class="card panel fade-in">
        <h2>Feature highlights</h2>
        <ul class="list">
            <li><span>Responsive design with dark/light themes</span><span class="tag ok">Done</span></li>
            <li><span>Full project CRUD with skills tagging</span><span class="tag ok">Done</span></li>
            <li><span>GitHub repository sync via REST API</span><span class="tag ok">Done</span></li>
            <li><span>Role-based access: Student / Admin</span><span class="tag ok">Done</span></li>
        </ul>
    </article>

    <article class="card panel fade-in">
        <h2>Platform capabilities</h2>
        <ul class="list">
            <li><span>ASP.NET Core MVC (.NET 10)</span><span class="tag ok">Active</span></li>
            <li><span>Entity Framework Core with SQLite</span><span class="tag ok">Active</span></li>
            <li><span>ASP.NET Core Identity authentication</span><span class="tag ok">Active</span></li>
            <li><span>GitHub REST API v3 integration</span><span class="tag ok">Active</span></li>
        </ul>
    </article>
</section>
