@model IEnumerable<dynamic>

@{
    // Admin/reviewer page for moderation and system-level visibility.
    ViewData["Title"] = "Admin";
}

@* Placeholder for Part III:
   secure this page with [Authorize(Roles = "Admin")] and data-backed review queues. *@
<section class="hero fade-in">
    <h1>Admin Review Center</h1>
    <p class="subtitle">Instructor/reviewer workspace for visibility, approvals, and quality control across student submissions.</p>
    <div class="hero-actions">
        <a href="#" class="btn btn-primary">Review Queue</a>
        <a asp-controller="Home" asp-action="Dashboard" class="btn">Student View</a>
    </div>
</section>

<section class="grid">
    <article class="card kpi fade-in">
        <h3>Pending Review</h3>
        <p class="metric">@ViewBag.PendingReviews</p>
        <p class="muted">Awaiting approval</p>
    </article>
    <article class="card kpi fade-in">
        <h3>Flagged</h3>
        <p class="metric">@ViewBag.FlaggedReviews</p>
        <p class="muted">Need moderator action</p>
    </article>
    <article class="card kpi fade-in">
        <h3>Approved</h3>
        <p class="metric">@ViewBag.ApprovedReviews</p>
        <p class="muted">This month</p>
    </article>
    <article class="card kpi fade-in">
        <h3>Role Health</h3>
        <p class="status-row"><span class="dot"></span> @ViewBag.RoleHealth</p>
        <p class="muted">Policy checks passing</p>
    </article>

    <article class="card panel fade-in">
        <h2>Moderation feed</h2>
        @if (!Model.Any())
        {
            <p class="muted">no moderation items yet.</p>
        }
        else
        {
            <ul class="list">
                @foreach (var item in Model)
                {
                    <li>
                        <span>@(item.Notes ?? "review update")</span>
                        <span class="tag">@item.Decision</span>
                    </li>
                }
            </ul>
        }
    </article>

    <article class="card panel fade-in">
        <h2>Role matrix (starter)</h2>
        <ul class="list">
            <li><span>Guest: view landing + register</span><span class="tag ok">Defined</span></li>
            <li><span>Student: CRUD own projects</span><span class="tag ok">Defined</span></li>
            <li><span>Admin: review + moderation</span><span class="tag ok">Defined</span></li>
        </ul>
    </article>
</section>
