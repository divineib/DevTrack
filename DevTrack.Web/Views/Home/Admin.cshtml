@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Admin";
}

<section class="hero fade-in">
    <h1>Admin Review Center</h1>
    <p class="subtitle">Instructor workspace for visibility, approvals, and quality control across student submissions.</p>
    <div class="hero-actions">
        <a asp-controller="Projects" asp-action="Index" class="btn btn-primary">All Projects</a>
        <a asp-controller="Home" asp-action="Dashboard" class="btn">Student View</a>
    </div>
</section>

<section class="grid">
    <article class="card kpi fade-in">
        <h3>Pending Review</h3>
        <p class="metric">@ViewBag.PendingReviews</p>
        <p class="muted">Awaiting approval</p>
    </article>
    <article class="card kpi fade-in">
        <h3>Flagged</h3>
        <p class="metric">@ViewBag.FlaggedReviews</p>
        <p class="muted">Need moderator action</p>
    </article>
    <article class="card kpi fade-in">
        <h3>Approved</h3>
        <p class="metric">@ViewBag.ApprovedReviews</p>
        <p class="muted">Total approved</p>
    </article>
    <article class="card kpi fade-in">
        <h3>System Status</h3>
        <p class="status-row"><span class="dot"></span> @ViewBag.RoleHealth</p>
        <p class="muted">All roles active</p>
    </article>

    <article class="card panel fade-in">
        <h2>Moderation feed</h2>
        @if (!Model.Any())
        {
            <p class="muted">no moderation items yet.</p>
        }
        else
        {
            <ul class="list">
                @foreach (var item in Model)
                {
                    <li>
                        <span>@(item.Notes ?? "review update")</span>
                        <span class="tag">@item.Decision</span>
                    </li>
                }
            </ul>
        }
    </article>

    <article class="card panel fade-in">
        <h2>Role matrix</h2>
        <ul class="list">
            <li><span>Guest: view landing page and register</span><span class="tag ok">Active</span></li>
            <li><span>Student: CRUD own projects, tag skills</span><span class="tag ok">Active</span></li>
            <li><span>Admin: view all projects, moderation feed</span><span class="tag ok">Active</span></li>
        </ul>
    </article>
</section>
