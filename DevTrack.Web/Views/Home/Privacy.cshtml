@{
    ViewData["Title"] = "Privacy";
}

<section class="hero fade-in">
    <h1>Privacy & Data Use</h1>
    <p class="subtitle">
        DevTrack is a course project application. User records and project data are protected
        by ASP.NET Core Identity authentication and role-based authorization.
    </p>
</section>

<section class="grid">
    <article class="card panel fade-in">
        <h2>Data handling</h2>
        <ul class="list">
            <li><span>Passwords hashed via ASP.NET Core Identity</span><span class="tag ok">Active</span></li>
            <li><span>Theme preference stored in local browser storage</span><span class="tag">Client-side</span></li>
            <li><span>SQLite database stored on the server</span><span class="tag ok">Active</span></li>
        </ul>
    </article>

    <article class="card panel fade-in">
        <h2>Access controls</h2>
        <ul class="list">
            <li><span>Cookie-based authentication for all protected pages</span><span class="tag ok">Active</span></li>
            <li><span>Role-based permissions (Student / Admin)</span><span class="tag ok">Active</span></li>
            <li><span>Project ownership enforced per user</span><span class="tag ok">Active</span></li>
        </ul>
    </article>
</section>
