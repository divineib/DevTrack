@{
    ViewData["Title"] = "Privacy";
}

<section class="hero fade-in">
    <h1>Privacy & Data Use</h1>
    <p class="subtitle">
        DevTrack is a course project shell. Data shown in this phase is demo content. In later phases,
        user records and project data will be protected by authentication and role-based authorization.
    </p>
</section>

<section class="grid">
    <article class="card panel fade-in">
        <h2>Current implementation notes</h2>
        <ul class="list">
            <li><span>No production personal data is collected yet</span><span class="tag ok">Current</span></li>
            <li><span>Theme preference stored in local browser storage</span><span class="tag">Client-side</span></li>
            <li><span>Authentication and database integration planned next</span><span class="tag warn">Upcoming</span></li>
        </ul>
    </article>

    <article class="card panel fade-in">
        <h2>Future safeguards</h2>
        <ul class="list">
            <li><span>Secure password handling via ASP.NET Identity</span><span class="tag">Planned</span></li>
            <li><span>Role-based permissions (Student/Admin)</span><span class="tag">Planned</span></li>
            <li><span>Audit trail for admin moderation actions</span><span class="tag">Planned</span></li>
        </ul>
    </article>
</section>
